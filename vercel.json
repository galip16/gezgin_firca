{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.gezgin-firca.vercel.app"
        }
      ],
      "destination": "https://gezgin-firca.vercel.app/$1",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/cron/dummy-order",
      "schedule": "0 9 * * *"
    }
  ]
}